{
  "name": "feathersjs-mcp-server",
  "version": "1.0.7",
  "description": "MCP server for FeathersJS — semantic search over v5/v6 docs with AI-assisted contribution via GitHub PRs",
  "main": "dist/index.js",
  "bin": {
    "feathersjs-mcp": "./bin/feathersjs-mcp.js",
    "feathersjs-mcp-server": "./bin/feathersjs-mcp.js"
  },
  "keywords": [
    "mcp",
    "feathersjs",
    "feathers",
    "model-context-protocol",
    "claude",
    "ai",
    "documentation",
    "semantic-search"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TeaBreeze00/cspc319_feathersJS_C.git"
  },
  "homepage": "https://github.com/TeaBreeze00/cspc319_feathersJS_C#readme",
  "bugs": {
    "url": "https://github.com/TeaBreeze00/cspc319_feathersJS_C/issues"
  },
  "author": "TeaBreeze00",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:coverage": "jest --coverage --watchman=false",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write src/ tests/",
    "prepare": "npm run build",
    "generate:embeddings": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true,\"target\":\"ES2020\"}' scripts/generate-embeddings.ts",
    "ingest:v6": "node scripts/ingest-v6-docs.js",
    "rebuild:kb": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true,\"target\":\"ES2020\"}' scripts/improved-chunking.ts && npm run generate:embeddings",
    "update:kb": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true,\"target\":\"ES2020\"}' scripts/incremental-update.ts",
    "test:submit": "ts-node --compiler-options '{\"module\":\"CommonJS\",\"esModuleInterop\":true,\"target\":\"ES2020\"}' scripts/test-submit.ts"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.18.0"
  }
}
